# Agent workspace directory (where agents run tasks)
# Dev: set to your target project. Production: defaults to cwd()
WORKSPACE=/Users/you/projects/my-app

# Optional: remote channel
# ABLY_API_KEY=

# Optional: Telegram single-bot (one bot, all agents via reply-chain menu)
# TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: Telegram whitelist (comma-separated TG user IDs; empty = allow all)
# TELEGRAM_ALLOWED_USERS=123456789,987654321
